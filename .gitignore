build/

# XcodeGen-generated project. project.yml is the source of truth;
# the .xcodeproj is regenerated locally via `make project`.
SwiftUITemplate.xcodeproj/

*.xcuserstate
*.xcuserdatad
*.xcworkspacedata
*.xccheckout

.swiftpm/configuration/registries.json
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.swiftpm/xcode/xcuserdata/

.netrc

# Web (React/Vite) layer
Web/node_modules/
Web/dist/
Web/*.tsbuildinfo

# Built web app — generated by `make web`; keep the dir (via .gitkeep) so the
# Xcode folder reference always resolves.
Resources/web/*
!Resources/web/.gitkeep
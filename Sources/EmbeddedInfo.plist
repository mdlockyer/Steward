	     Local-only (does not relax ATS for the public internet); harmless in
	     RELEASE, which loads the bundled web app over the app:// scheme. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>

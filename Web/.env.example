# Steward — copy this file to .env.local and fill in your key.
# .env.local is server-side only; the key is never bundled into the browser.
# Do not commit a real key.

ANTHROPIC_API_KEY=

# Optional: override the Claude model (default: claude-sonnet-4-6)
STEWARD_MODEL=claude-sonnet-4-6

# OpenAI provider (API-key path). Key from platform.openai.com.
OPENAI_API_KEY=
# Optional: override the OpenAI model (configurable because model names change)
OPENAI_MODEL=gpt-4o

# Default provider when the UI doesn't specify one: anthropic | openai
STEWARD_PROVIDER=anthropic
